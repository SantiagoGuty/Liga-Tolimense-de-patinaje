# -------------------------------------
# 🌍 AWS / Amplify “infra‑as‑code”
# -------------------------------------
# Ignore all of amplify/, then un‑ignore just the infra definitions + team info
amplify/*
!amplify/backend/
!amplify/team-provider-info.json
!amplify/cli.json

# Now ignore Amplify’s local state, logs, mocks, etc.
amplify/.config/
amplify/#current-cloud-backend/
amplify/logs/
amplify/mock-data/
amplify/mock-api-resources/
amplify/backend/.temp/
amplify/backend/amplify-meta.json

# -------------------------------------
# Other auto‑generated/mobile configs
# -------------------------------------
build/
awsconfiguration.json
amplifyconfiguration.json
amplifyconfiguration.dart
amplify-build-config.json
amplify-gradle-config.json
amplifytools.xcconfig
.secret-*
**.sample

# -------------------------------------
# Keep TS project refs
# -------------------------------------
!tsconfig.app.json
!tsconfig.node.json
